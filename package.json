{
  "name": "winnode",
  "version": "1.0.1",
  "description": "WinScan Tx SDK - Transaction toolkits for Cosmos SDK and EVM chains",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cosmos",
    "evm",
    "blockchain",
    "transaction",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "cosmjs-types": "^0.11.0",
    "ethers": "^6.17.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "tsup": "^8.3.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winnode/sdk-cosmos.git"
  },
  "bugs": {
    "url": "https://github.com/winnode/sdk-cosmos/issues"
  },
  "homepage": "https://github.com/winnode/sdk-cosmos#readme"
}
